# FSS office inventory template (practice/lab)
#
# This file stores endpoint/user mapping only.
# Keep real passwords in a secure vault and inject at runtime.
#
# Replace all <YOUR_*_IP> placeholders with actual values before use.

# ===== Common account =====
SSH_USER=disadm
SSH_PORT=10022
# SSH_PASSWORD=<set-at-runtime>

# ===== VMware / office infra =====
ESXI_HOST=<YOUR_ESXI_IP>
ESXI_WEB_URL=https://<YOUR_ESXI_IP>
# ESXI_USER=k8s
# ESXI_PASSWORD=<set-at-runtime>

NFS_SIM_HOST=<YOUR_NFS_IP>
NFS_SIM_WEB_URL=http://<YOUR_NFS_WEB_IP>:8080
# NFS_USER=admin
# NFS_PASSWORD=<set-at-runtime>

# Office bastion (not move-in target)
BASTION_OFFICE_IP=<YOUR_BASTION_IP>
# Internal-side bastion IP mapping used in docs
BASTION_INTERNAL_IP=<YOUR_BASTION_INTERNAL_IP>

# ===== Kubernetes nodes =====
MASTER1_IP=<YOUR_MASTER_IP>
WORKER1_IP=<YOUR_WORKER1_IP>
WORKER2_IP=<YOUR_WORKER2_IP>
WORKER_ML1_IP=<YOUR_WORKER_ML1_IP>

MASTER1_HOSTNAME=master-1
WORKER1_HOSTNAME=worker-1
WORKER2_HOSTNAME=worker-2
WORKER_ML1_HOSTNAME=worker-ml-1

# NFS side NIC is expected on workers (<YOUR_NFS_CIDR>.x)
WORKER_NFS_CIDR=<YOUR_NFS_CIDR>/24

# ===== Load Balancer =====
METALLB_SINGLE_IP=<YOUR_LB_IP>
METALLB_RANGE=<YOUR_LB_IP>-<YOUR_LB_IP>

# ===== Harbor / GitLab / ELTFR =====
HARBOR_OFFICE_IP=<YOUR_HARBOR_IP>
HARBOR_INTERNAL_IP=<YOUR_HARBOR_IP>
HARBOR_WEB_URL=http://<YOUR_HARBOR_IP>

GITLAB_OFFICE_IP=<YOUR_GITLAB_IP>
GITLAB_INTERNAL_IP=<YOUR_GITLAB_IP>

ELTFR_OFFICE_IP=<YOUR_ELTFR_IP>
ELTFR_INTERNAL_IP=<YOUR_ELTFR_IP>
ELTFR_API_URL=http://<YOUR_ELTFR_IP>:8001
AIRFLOW_UI_URL=http://<YOUR_ELTFR_IP>:8888

# ===== Harbor robot users (username only, password from vault) =====
HARBOR_ROBOT_CICD_USER='robot$ci-cd'
# HARBOR_ROBOT_CICD_PASSWORD=<set-at-runtime>

HARBOR_ROBOT_DIS_USER='robot$dis'
# HARBOR_ROBOT_DIS_PASSWORD=<set-at-runtime>

# ===== DNS / network profile (office simulation) =====
NETWORK_CIDR_PREFIX=24
GATEWAY=<YOUR_GATEWAY_IP>
DNS_SERVERS=<YOUR_DNS_SERVERS>
