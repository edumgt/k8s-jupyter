# FSS office inventory template (practice/lab)
#
# This file stores endpoint/user mapping only.
# Keep real passwords in a secure vault and inject at runtime.

# ===== Common account =====
SSH_USER=disadm
SSH_PORT=10022
# SSH_PASSWORD=<set-at-runtime>

# ===== VMware / office infra =====
ESXI_HOST=192.168.56.70
ESXI_WEB_URL=https://192.168.56.70
# ESXI_USER=k8s
# ESXI_PASSWORD=<set-at-runtime>

NFS_SIM_HOST=192.168.10.2
NFS_SIM_WEB_URL=http://192.168.56.75:8080
# NFS_USER=admin
# NFS_PASSWORD=<set-at-runtime>

# Office bastion (not move-in target)
BASTION_OFFICE_IP=192.168.56.76
# Internal-side bastion IP mapping used in docs
BASTION_INTERNAL_IP=192.168.56.100

# ===== Kubernetes nodes =====
MASTER1_IP=192.168.56.10
WORKER1_IP=192.168.56.11
WORKER2_IP=192.168.56.12
WORKER_ML1_IP=192.168.56.13

MASTER1_HOSTNAME=master-1
WORKER1_HOSTNAME=worker-1
WORKER2_HOSTNAME=worker-2
WORKER_ML1_HOSTNAME=worker-ml-1

# NFS side NIC is expected on workers (192.168.10.x)
WORKER_NFS_CIDR=192.168.10.0/24

# ===== Load Balancer =====
METALLB_SINGLE_IP=192.168.56.77
METALLB_RANGE=192.168.56.77-192.168.56.77

# ===== Harbor / GitLab / ELTFR =====
HARBOR_OFFICE_IP=192.168.56.72
HARBOR_INTERNAL_IP=192.168.56.72
HARBOR_WEB_URL=http://192.168.56.72

GITLAB_OFFICE_IP=192.168.56.71
GITLAB_INTERNAL_IP=192.168.56.71

ELTFR_OFFICE_IP=192.168.56.74
ELTFR_INTERNAL_IP=192.168.56.74
ELTFR_API_URL=http://192.168.56.74:8001
AIRFLOW_UI_URL=http://192.168.56.74:8888

# ===== Harbor robot users (username only, password from vault) =====
HARBOR_ROBOT_CICD_USER='robot$ci-cd'
# HARBOR_ROBOT_CICD_PASSWORD=<set-at-runtime>

HARBOR_ROBOT_DIS_USER='robot$dis'
# HARBOR_ROBOT_DIS_PASSWORD=<set-at-runtime>

# ===== DNS / network profile (office simulation) =====
NETWORK_CIDR_PREFIX=24
GATEWAY=192.168.56.1
DNS_SERVERS=192.168.56.1,1.1.1.1,8.8.8.8
