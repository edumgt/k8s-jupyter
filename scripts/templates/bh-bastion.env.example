# Example parameters for scripts/vmware_create_bastion_bh.sh
#
# Usage:
#   source scripts/templates/bh-bastion.env.example
#   bash scripts/vmware_create_bastion_bh.sh \
#     --vars-file "${PACKER_VARS}" \
#     --bastion-name "${BASTION_NAME}" \
#     --ssh-user "${SSH_USER}" \
#     --ssh-password "${SSH_PASSWORD}" \
#     --ssh-port "${SSH_PORT}" \
#     --disadm-password "${DISADM_PASSWORD}" \
#     --pdsh-group-hosts "${PDSH_GROUP_HOSTS}" \
#     --static-network \
#     --static-ip "${STATIC_IP}" \
#     --gateway "${GATEWAY}" \
#     --dns-servers "${DNS_SERVERS}" \
#     --network-cidr-prefix "${NETWORK_CIDR_PREFIX}"

PACKER_VARS="packer/variables.vmware.auto.pkrvars.hcl"
BASTION_NAME="bh"

# Bootstrap account in source VM
SSH_USER="ubuntu"
SSH_PASSWORD="CHANGE_ME"
SSH_PORT="22"

# disadm account in bastion VM
DISADM_PASSWORD="CHANGE_ME"

# Optional: cluster nodes for pdsh group file
PDSH_GROUP_HOSTS="<YOUR_MASTER_IP>,<YOUR_WORKER1_IP>,<YOUR_WORKER2_IP>,<YOUR_WORKER_ML1_IP>"

# Optional static IP for bh
STATIC_IP="<YOUR_BASTION_STATIC_IP>"
NETWORK_CIDR_PREFIX="24"
GATEWAY="<YOUR_GATEWAY_IP>"
DNS_SERVERS="<YOUR_GATEWAY_IP>,1.1.1.1,8.8.8.8"

