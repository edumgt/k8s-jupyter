# FSS office simulation bootstrap template
# Usage:
#   cp scripts/templates/fss-office-dev.env.example /home/disadm/fss-support/k8s-dev/runtime/fss-office-dev.env
#   vi /home/disadm/fss-support/k8s-dev/runtime/fss-office-dev.env
#   bash scripts/bootstrap_3node_k8s_ova.sh --config /home/disadm/fss-support/k8s-dev/runtime/fss-office-dev.env
#
# Note:
# - worker-ml-1 is mapped to WORKER3_* for now.
# - Fill SSH_PASSWORD or SSH_KEY_PATH before execution.

SSH_USER=disadm
SSH_PASSWORD=
# SSH_KEY_PATH=/home/disadm/.ssh/id_rsa
SSH_PORT=10022

CONTROL_PLANE_SSH_HOST=192.168.56.10
CONTROL_PLANE_HOSTNAME=master-1
CONTROL_PLANE_IP=192.168.56.10
REGISTRY_HOSTNAME=harbor.local
REGISTRY_IP=192.168.56.72

WORKER1_SSH_HOST=192.168.56.11
WORKER1_HOSTNAME=worker-1
WORKER1_IP=192.168.56.11

WORKER2_SSH_HOST=192.168.56.12
WORKER2_HOSTNAME=worker-2
WORKER2_IP=192.168.56.12

# worker-ml-1
WORKER3_SSH_HOST=192.168.56.13
WORKER3_HOSTNAME=worker-ml-1
WORKER3_IP=192.168.56.13

NETWORK_CIDR_PREFIX=24
GATEWAY=192.168.56.1
# office DNS simulator (replace after move-in)
DNS_SERVERS=192.168.56.1,1.1.1.1,8.8.8.8
NET_INTERFACE=

TOKEN_TTL=2h

APPLY_OVERLAY=1
ENVIRONMENT=dev
OVERLAY=dev-3node
REMOTE_REPO_ROOT=/home/disadm/fss-support/k8s-dev

SETUP_INGRESS_STACK=1
METALLB_ADDRESS_RANGE=192.168.56.77-192.168.56.77
INGRESS_LB_IP=192.168.56.77
METALLB_MANIFEST=
INGRESS_MANIFEST=

SKIP_NETWORK=0
SKIP_JOIN=0

