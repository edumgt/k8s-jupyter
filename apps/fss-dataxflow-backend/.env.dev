PLATFORM_ENV=dev
PLATFORM_MONGO_URL=mongodb://mongodb:27017/platform_dev
PLATFORM_BACKEND_URL=http://api.dataxflow.platform.local/docs
PLATFORM_FRONTEND_URL=http://dataxflow.platform.local
PLATFORM_CONTROL_PLANE_URL=http://dataxflow.platform.local/#control-plane
PLATFORM_ADMIN_URL=http://dataxflow.platform.local/#admin
PLATFORM_PYPI_INDEX_URL=http://nexus.platform.local/repository/pypi-all/simple
PLATFORM_NPM_REGISTRY=http://nexus.platform.local/repository/npm-all/
NEXUS_PYTHON_SEED_FILE=scripts/offline/python-dev-seed.txt
PLATFORM_CORS_ALLOW_ORIGINS=http://dataxflow.platform.local,http://dev.dataxflow.platform.local,http://www.dataxflow.platform.local,http://localhost:30080,http://localhost:5173
PLATFORM_CORS_ALLOW_ORIGIN_REGEX=^https?://([a-z0-9-]+\.)?dataxflow\.local(:\d+)?$
PLATFORM_CORS_ALLOW_CREDENTIALS=true
